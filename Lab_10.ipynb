      "source": [
      
        "def get_user_graph_input():\n",
        "    n = int(input(\"Enter the number of vertices: \"))\n",
        "    graph = []\n",
        "    print(f\"Enter the {n}x{n} adjacency matrix row by row. Use 'inf' for no direct edge, and 0 for self-loops:\")\n",
        "    for i in range(n):\n",
        "        row_str = input(f\"Enter row {i+1} (space-separated values): \")\n",
        "        row_values = []\n",
        "        for val_str in row_str.split():\n",
        "            if val_str.lower() == 'inf':\n",
        "                row_values.append(float('inf'))\n",
        "            else:\n",
        "                row_values.append(int(val_str))\n",
        "        if len(row_values) != n:\n",
        "            raise ValueError(f\"Row {i+1} must have {n} values. Got {len(row_values)}.\")\n",
        "        graph.append(row_values)\n",
        "    return graph\n",
        "\n",
        "user_graph = get_user_graph_input()\n",
        "print(\"\\nUser-provided graph matrix:\")\n",
        "for row in user_graph:\n",
        "    print(row)\n",
        "\n",
        "\n",
      
        "def detect_negative_cycle(graph):\n",
        "    n = len(graph)\n",
        "    dist = []\n",
        "    for i in range(n):\n",
        "        dist.append(graph[i][:])\n",
        "\n",
        "   
        "    for k in range(n):\n",
        "        for i in range(n):\n",
        "            for j in range(n):\n",
        "               
        "                if dist[i][k] != float('inf') and dist[k][j] != float('inf'):\n",
        "                    dist[i][j] = min(dist[i][j], dist[i][k] + dist[k][j])\n",
        "\n",
        "   
        "    for i in range(n):\n",
        "        if dist[i][i] < 0:\n",
        "            return True\n",
        "    return False\n",
        "\n",
        "print(\"\\n--- Negative Cycle Detection ---\")\n",
        "if detect_negative_cycle(user_graph):\n",
        "    print(\"The graph contains a negative cycle.\")\n",
        "else:\n",
        "    print(\"The graph does not contain a negative cycle.\")\n",
        "\n",
        "\n",
        
       
        "def reconstruct_path(parent, start, end):\n",
        "    if parent[start][end] == -1:\n",
        "        return [] # No path\n",
        "    path = []\n",
        "    curr = end\n",
        "    while curr != start:\n",
        "        if curr == -1 or curr == None: # Handle cases where path is broken or not set\n",
        "            return []\n",
        "        path.insert(0, curr)\n",
        "        curr = parent[start][curr]\n",
        "    path.insert(0, start)\n",
        "    return path\n",
        "\n",
        "def floyd_warshall_with_path(graph):\n",
        "    n = len(graph)\n",
        "    dist = []\n",
        "    parent = [] # To reconstruct path\n",
        "\n",
        "    for i in range(n):\n",
        "        dist.append(graph[i][:])\n",
        "        parent.append([-1] * n) # Initialize parent matrix with -1 (no intermediate path)\n",
        "        for j in range(n):\n",
        "            if i != j and graph[i][j] != float('inf'):\n",
        "                parent[i][j] = i # Direct edge from i to j, parent is i\n",
        "            elif i == j:\n",
        "                parent[i][j] = i # Self loop path via self\n",
        "\n",
        "    for k in range(n):\n",
        "        for i in range(n):\n",
        "            for j in range(n):\n",
        "                if dist[i][k] != float('inf') and dist[k][j] != float('inf'):\n",
        "                    if dist[i][k] + dist[k][j] < dist[i][j]:\n",
        "                        dist[i][j] = dist[i][k] + dist[k][j]\n",
        "                        parent[i][j] = parent[k][j]\n",
        "\n",
        "   
        "    for i in range(n):\n",
        "        if dist[i][i] < 0:\n",
        "            print(\"Warning: Negative cycle detected. Shortest paths might be ill-defined.\")\n",
        "\n",
        "    return dist, parent\n",
        "\n",
        "print(\"\\n--- Shortest Path between Two Vertices ---\")\n",
        "start_node_idx = int(input(\"Enter the starting vertex index (0-indexed) for path reconstruction: \"))\n",
        "end_node_idx = int(input(\"Enter the ending vertex index (0-indexed) for path reconstruction: \"))\n",
        "\n",
       
        "dist_matrix, parent_matrix = floyd_warshall_with_path(user_graph)\n",
        "\n",
       
        "n_nodes = len(user_graph)\n",
        "if not (0 <= start_node_idx < n_nodes and 0 <= end_node_idx < n_nodes):\n",
        "    print(\"Error: Start or end vertex index is out of bounds.\")\n",
        "else:\n",
        "    print(f\"\\nShortest distance from vertex {start_node_idx} to {end_node_idx}: {dist_matrix[start_node_idx][end_node_idx]}\")\n",
        "\n",
        "    path = reconstruct_path(parent_matrix, start_node_idx, end_node_idx)\n",
        "    if path:\n",
        "        print(f\"Shortest path: {' -> '.join(map(str, path))}\")\n",
        "    else:\n",
        "        print(f\"No path exists from vertex {start_node_idx} to {end_node_idx}.\")\n",
        "\n",
        "\n",
     
        "import heapq\n",
        "\n",
        "def dijkstra(graph, start_node):\n",
        "    n = len(graph)\n",
        "    distances = [float('inf')] * n\n",
        "    distances[start_node] = 0\n",
        "    priority_queue = [(0, start_node)] # (distance, vertex)\n",
        "\n",
        "    while priority_queue:\n",
        "        dist, u = heapq.heappop(priority_queue)\n",
        "\n",
        "        if dist > distances[u]:\n",
        "            continue\n",
        "\n",
        "        for v in range(n):\n",
        "          
        "            if u != v and graph[u][v] != float('inf'):\n",
        "                if distances[u] + graph[u][v] < distances[v]:\n",
        "                    distances[v] = distances[u] + graph[u][v]\n",
        "                    heapq.heappush(priority_queue, (distances[v], v))\n",
        "\n",
        "    return distances\n",
        "\n",
        "print(\"\\n--- Comparison with Dijkstra's Algorithm ---\")\n",
        "print(\"Floyd-Warshall calculates all-pairs shortest paths. It can handle negative edge weights (but not negative cycles for true shortest paths).\")\n",
        "print(\"Dijkstra's algorithm calculates single-source shortest paths and requires non-negative edge weights.\")\n",
        "\n",
       
        "has_negative_weights = False\n",
        "for r in user_graph:\n",
        "    for val in r:\n",
        "        if val < 0:\n",
        "            has_negative_weights = True\n",
        "            break\n",
        "    if has_negative_weights:\n",
        "        break\n",
        "\n",
        "if has_negative_weights:\n",
        "    print(\"\\nWarning: The provided graph contains negative edge weights. Dijkstra's algorithm might produce incorrect results.\")\n",
        "    print(\"Floyd-Warshall (if no negative cycle) is more suitable for graphs with negative weights.\")\n",
        "\n",
       
        "if 'start_node_idx' not in locals() or not (0 <= start_node_idx < len(user_graph)):\n",
        "    start_dijkstra_node = 0\n",
        "    print(f\"\\nUsing default starting vertex 0 for Dijkstra's, as a valid start node was not provided or was out of bounds.\")\n",
        "else:\n",
        "    start_dijkstra_node = start_node_idx\n",
        "    print(f\"\\nRunning Dijkstra's algorithm from vertex {start_dijkstra_node}:\")\n",
        "\n",
        "dijkstra_distances = dijkstra(user_graph, start_dijkstra_node)\n",
        "print(f\"Distances from {start_dijkstra_node}: {dijkstra_distances}\")\n",
        "\n",
        "print(\"\\nComparing the row for the source from Floyd-Warshall results with Dijkstra's results:\")\n",
        "print(f\"Floyd-Warshall (row {start_dijkstra_node}): {dist_matrix[start_dijkstra_node]}\")\n",
        "print(f\"Dijkstra's results: {dijkstra_distances}\")"
      ],
